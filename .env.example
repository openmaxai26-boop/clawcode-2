# Claw Code — Configuration de l'environnement
# Copiez ce fichier en .env et renseignez vos valeurs
# NE JAMAIS committer le fichier .env (il est dans .gitignore)

# ---------------------------------------------------------
# Option 1 : Anthropic (recommandé pour les modèles Claude)
# ---------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------
# Option 2 : Groq (OpenAI-compatible, modèles open-source)
# ---------------------------------------------------------
OPENAI_API_KEY=gsk_your_groq_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Modèles Groq disponibles :
#   llama-3.3-70b-versatile   (recommandé — équilibre vitesse/qualité)
#   llama-3.1-8b-instant      (ultra rapide)
#   mixtral-8x7b-32768        (fenêtre de contexte large)
#   gemma2-9b-it              (léger et efficace)

# ---------------------------------------------------------
# Option 3 : OpenRouter (accès à de nombreux modèles)
# ---------------------------------------------------------
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------
# Optionnel : proxy HTTP/HTTPS
# ---------------------------------------------------------
# HTTPS_PROXY=http://proxy.example.com:3128
# HTTP_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1
